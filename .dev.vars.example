# Copy this file to .dev.vars and fill in values for local development.
# .dev.vars is gitignored. Never commit real secrets.
#
# NOTE: Cloudflare D1 is accessed via the "DB" Workers binding — no connection
# string or env var is needed. The binding is declared in wrangler.jsonc under
# d1_databases. For local dev, wrangler automatically provides it when you run
# "npm run dev" after applying migrations with "npm run db:migrate:local".

APP_ENV=development
PUBLIC_SITE_URL=http://localhost:5173

# Resend (required for contact form and portal email notifications)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=From the Heart Tutoring <info@fromthehearttutoring.com>
CONTACT_TO_EMAIL=info@fromthehearttutoring.com

# Clerk auth (required for portal login — spec 01)
# Get these from: https://dashboard.clerk.com → Your app → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_SIGN_IN_URL=/portal/login
CLERK_SIGN_UP_URL=/portal/register

# Stripe (required for billing — spec 07)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Twilio (required for SMS notifications — spec 09)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_PHONE=+1...

# Client-exposed Vite vars (safe to expose in the browser)
# Clerk reads the publishable key server-side from the session state,
# so VITE_CLERK_PUBLISHABLE_KEY is only needed if server-side auth is skipped.
VITE_PUBLIC_SITE_URL=http://localhost:5173
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
